{
  "name": "excalidraw-dash",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hostable Excalidraw with a dashboard: folders, search, filtering and login.",
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "predev": "node scripts/copy-excalidraw-assets.mjs",
    "dev": "next dev",
    "prebuild": "node scripts/copy-excalidraw-assets.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "setup": "node scripts/migrate.mjs && node scripts/seed.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node scripts/migrate.mjs",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "seed": "node scripts/seed.mjs"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "0.17.6",
    "bcryptjs": "2.4.3",
    "drizzle-orm": "^0.36.4",
    "jose": "5.9.6",
    "next": "14.2.35",
    "pg": "^8.13.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/node": "20.16.11",
    "@types/pg": "^8.11.10",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.20",
    "drizzle-kit": "^0.28.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.35",
    "postcss": "8.4.47",
    "tailwindcss": "3.4.13",
    "typescript": "5.6.3"
  }
}
