# --- ExcalidrawDash configuration ---

# Password for the bundled Postgres (docker-compose `db` service). REQUIRED — the
# db container refuses to start without it. Generate one with: openssl rand -base64 32
POSTGRES_PASSWORD="change-me-to-a-long-random-password"

# PostgreSQL connection string.
# Local dev (matches docker-compose `db` service): start it with `docker compose up -d db`.
# Keep the password here in sync with POSTGRES_PASSWORD above.
DATABASE_URL="postgresql://excalidash:change-me-to-a-long-random-password@localhost:5432/excalidash"

# Max connections in the pg pool (optional).
DATABASE_POOL_MAX="10"

# Secret used to sign session cookies (JWT). CHANGE THIS in production.
# Generate one with:  openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string-please"

# Set to "true" to disable public self-registration (invite/admin-only).
DISABLE_REGISTRATION="false"
